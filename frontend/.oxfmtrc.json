{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "sortPackageJson": false,
  "sortImports": {
    "order": "asc"
  },
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "pacakge.json",
    "tsconfig.json",
    "tsconfig.app.json",
    "tsconfig.node.json",
    "build",
    "routeTree.gen.ts"
  ]
}
